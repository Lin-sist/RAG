# Copy this file to .env.local and adjust host ports per machine.
# Usage:
#   docker compose --env-file .env.local -f docker-compose.yml up -d

MYSQL_HOST_PORT=3306
REDIS_HOST_PORT=6379
MINIO_API_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001
MILVUS_GRPC_HOST_PORT=19530
MILVUS_HTTP_HOST_PORT=9091

# Backend runtime variables. Spring Boot does not automatically read this file;
# export them in your shell or IDE run configuration before starting rag-admin.
DB_PASSWORD=123456
REDIS_PASSWORD=123456
NVIDIA_API_KEY=

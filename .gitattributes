# 所有文本文件：入库时统一存为 LF，Windows checkout 时自动转 CRLF
* text=auto eol=lf

# Java / XML / YAML / Properties：明确强制 LF
*.java    text eol=lf
*.xml     text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.properties text eol=lf
*.sql     text eol=lf
*.md      text eol=lf
*.sh      text eol=lf

# 二进制文件：不做任何换行符转换
*.jar     binary
*.class   binary
*.png     binary
*.jpg     binary
*.gif     binary
*.zip     binary
*.gz      binary
